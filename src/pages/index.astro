          "@type": "Question",
          "name": "What file types are supported?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Currently PDFs with selectable text. DOCX and Markdown input are on the roadmap for future versions of this free PDF to quiz generator."
