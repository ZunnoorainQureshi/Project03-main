---
/**
 * MeshGradient — the single sanctioned home of the Vercel-inspired mesh
 * gradient. Five overlapping radial gradients (cyan / blue / pink / amber
 * / violet) blurred into a single atmospheric backdrop.
 *
 * Renders at hero scale only (≥ 800px wide). On viewports < 600px the
 * caller is expected to hide it (Tailwind `hidden sm:block`).
 */
---

<svg
  class="absolute inset-0 w-full h-full pointer-events-none select-none"
  viewBox="0 0 1440 720"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
  role="presentation"
>
  <defs>
    <radialGradient id="mg-1" cx="20%" cy="20%" r="55%">
      <stop offset="0%" stop-color="#007cf0" stop-opacity="0.9" />
      <stop offset="100%" stop-color="#007cf0" stop-opacity="0" />
    </radialGradient>
    <radialGradient id="mg-2" cx="80%" cy="15%" r="50%">
      <stop offset="0%" stop-color="#50e3c2" stop-opacity="0.85" />
      <stop offset="100%" stop-color="#50e3c2" stop-opacity="0" />
    </radialGradient>
    <radialGradient id="mg-3" cx="50%" cy="55%" r="60%">
      <stop offset="0%" stop-color="#ff0080" stop-opacity="0.75" />
      <stop offset="100%" stop-color="#ff0080" stop-opacity="0" />
    </radialGradient>
    <radialGradient id="mg-4" cx="15%" cy="85%" r="55%">
      <stop offset="0%" stop-color="#f9cb28" stop-opacity="0.7" />
      <stop offset="100%" stop-color="#f9cb28" stop-opacity="0" />
    </radialGradient>
    <radialGradient id="mg-5" cx="85%" cy="80%" r="55%">
      <stop offset="0%" stop-color="#7928ca" stop-opacity="0.8" />
      <stop offset="100%" stop-color="#7928ca" stop-opacity="0" />
    </radialGradient>
    <filter id="mg-blur" x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="60" />
    </filter>
  </defs>
  <g filter="url(#mg-blur)">
    <rect width="100%" height="100%" fill="url(#mg-1)" />
    <rect width="100%" height="100%" fill="url(#mg-2)" />
    <rect width="100%" height="100%" fill="url(#mg-3)" />
    <rect width="100%" height="100%" fill="url(#mg-4)" />
    <rect width="100%" height="100%" fill="url(#mg-5)" />
  </g>
</svg>
