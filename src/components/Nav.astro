---
/**
 * Nav — sticky 64px top bar. Logo wordmark left, link row centre,
 * primary CTA pill right. Collapses to logo + CTA on mobile.
 *
 * Sticky surface uses canvas (pure white) with a 1px hairline bottom border
 * per DESIGN.md nav-bar component.
 */

const currentPath = Astro.url.pathname;
const isApp = currentPath === '/app' || currentPath === '/app/';
---

<header class="sticky top-0 z-50 bg-canvas border-b border-hairline">
  <nav
    class="max-w-[1400px] mx-auto h-16 px-md sm:px-lg flex items-center justify-between gap-md"
    aria-label="Primary"
  >
    <!-- Logo wordmark -->
    <a href="/" class="flex items-center gap-3 group min-w-0" aria-label="Free PDF to Quiz — home">
      <img src="/favicon.svg" alt="" class="w-8 h-8 shrink-0" aria-hidden="true" />
      <span class="hidden xs:inline text-body-lg font-semibold tracking-tight text-ink group-hover:text-cyan-deep transition-colors whitespace-nowrap">
        Free PDF to Quiz
      </span>
    </a>

    <!-- Centre link row (desktop) -->
    <ul class="hidden md:flex items-center gap-xs text-body-sm text-body">
      <li>
        <a
          href="#features"
          class="px-sm py-xs rounded-full hover:bg-canvas-soft-2 hover:text-ink transition-colors"
        >
          Features
        </a>
      </li>
      <li>
        <a
          href="#how-it-works"
          class="px-sm py-xs rounded-full hover:bg-canvas-soft-2 hover:text-ink transition-colors"
        >
          How it works
        </a>
      </li>
      <li>
        <a
          href="#faq"
          class="px-sm py-xs rounded-full hover:bg-canvas-soft-2 hover:text-ink transition-colors"
        >
          FAQ
        </a>
      </li>
      <li>
        <a
          href="/about"
          class="px-sm py-xs rounded-full hover:bg-canvas-soft-2 hover:text-ink transition-colors"
        >
          About
        </a>
      </li>
      <li>
        <a
          href="/contact"
          class="px-sm py-xs rounded-full hover:bg-canvas-soft-2 hover:text-ink transition-colors"
        >
          Contact
        </a>
      </li>
      <li>
        <a
          href="/privacy"
          class="px-sm py-xs rounded-full hover:bg-canvas-soft-2 hover:text-ink transition-colors"
        >
          Privacy
        </a>
      </li>
      <li>
        <a
          href="/terms"
          class="px-sm py-xs rounded-full hover:bg-canvas-soft-2 hover:text-ink transition-colors"
        >
          Terms
        </a>
      </li>
    </ul>

    <!-- CTA cluster -->
    <div class="flex items-center gap-xs">
      <button
        id="theme-toggle"
        class="inline-flex items-center justify-center w-8 h-8 rounded-full hover:bg-canvas-soft-2 text-ink transition-colors cursor-pointer mr-sm"
        aria-label="Toggle dark mode"
      >
        <svg id="theme-icon-light" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="theme-icon-dark" class="hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <a
        href="https://github.com/ZunnoorainQureshi"
        class="hidden sm:inline-flex items-center h-7 px-xs text-body-sm-strong text-body hover:text-ink transition-colors"
        aria-label="View on GitHub"
      >
        GitHub
      </a>
      <a
        href="/app"
        class={`inline-flex items-center justify-center h-8 px-md text-body-sm-strong rounded-pill transition-all whitespace-nowrap shrink-0 ${
          isApp
            ? 'bg-canvas-soft-2 text-ink border border-hairline pointer-events-none'
            : 'bg-ink text-on-primary hover:opacity-90'
        }`}
      >
        {isApp ? 'Generator' : 'Start for free'}
      </a>
    </div>
  </nav>
</header>

<script>
  const toggleBtn = document.getElementById('theme-toggle');
  const iconLight = document.getElementById('theme-icon-light');
  const iconDark = document.getElementById('theme-icon-dark');
  
  function updateIcon() {
    if (document.documentElement.classList.contains('dark')) {
      iconDark?.classList.add('hidden');
      iconLight?.classList.remove('hidden');
    } else {
      iconLight?.classList.add('hidden');
      iconDark?.classList.remove('hidden');
    }
  }
  
  // Set initial icon
  updateIcon();
  
  toggleBtn?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateIcon();
  });
</script>
